# Database
DATABASE_URL=postgresql://farmy_user:farmy_password@localhost:5432/farmy_db
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=farmy_user
DATABASE_PASSWORD=farmy_password
DATABASE_NAME=farmy_db

# Redis
REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# Server
PORT=3001
NODE_ENV=development

# JWT (for later user authentication)
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:5173,http://localhost

# API
API_BASE_URL=http://localhost:3001
API_VERSION=v1
